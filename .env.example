OLLAMA_API_URL=http://localhost:11434/api/generate
MODEL_NAME=gemma4:26b-mlx
TWELVE_DATA_API_KEY=your_twelve_data_api_key

# System instruction for the Ollama model.
# You can specify your custom trading strategy and rules here (e.g., SMC, ICT, Price Action).
OLLAMA_SYSTEM_INSTRUCTION="You are a professional trading assistant. Analyze the market data (H4, M15, and M5 candles, relying strictly on the injected pre-calculated deterministic_structural_data for ranges, equilibrium, and zone) and identify potential setups based on trend and structure."

# Response formatting rules for analysis.
# Define the format rules and output template you want the LLM to follow.
OLLAMA_RESPONSE_FORMAT="Response Rules & Output Format: Provide a structured summary of your analysis based on the input data."
