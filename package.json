{
  "name": "smc-local-bot",
  "version": "1.0.0",
  "description": "Autonomous Forex (EUR/USD) market monitoring bot driven by a local Gemma 4 LLM via Ollama and TypeScript.",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "rm -rf dist && find . -name '*.js' -not -path './node_modules/*' -delete -o -name '*.d.ts' -not -path './node_modules/*' -delete -o -name '*.map' -not -path './node_modules/*' -delete",
    "build": "npm run clean && tsc",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "Artem Synytsin",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "node-telegram-bot-api": "^0.67.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/node-telegram-bot-api": "^0.64.14",
    "typescript": "^6.0.3"
  }
}